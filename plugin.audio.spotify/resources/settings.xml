<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings>
    <category label="11054">
        <setting id="my_recently_played_playlist_name" type="text" default="My Recently Played"
                 label="11069" help="Disable by setting string to NONE"/>
        <setting id="gap_between_playlist_tracks" type="number" default="0" label="11070"
	         help="Gap between tracks when playing a playlist (secs)"/>
        <setting id="use_spotify_normalization" type="bool" default="true" label="11075">
          <control type="toggle"/>
        </setting>
        <setting id="problem_with_terminate_streaming" type="bool" default="false" label="11086">
          <control type="toggle"/>
        </setting>
    </category>

    <category label="11055">
        <setting id="categoryDefaultView" type="text" default="" label="11020"/>
        <setting id="playlistDefaultView" type="text" default="" label="11031"/>
        <setting id="artistDefaultView" type="text" default="" label="11032"/>
        <setting id="albumDefaultView" type="text" default="" label="11033"/>
        <setting id="songDefaultView" type="text" default="" label="11034"/>
        <setting id="appendArtistToTitle" type="bool" default="false" label="11030"/>
    </category>

    <category label="11087">
        <setting id="connect_enabled" type="bool" default="true" label="11088"
                 visible="System.Platform.Linux + !System.Platform.Android">
          <control type="toggle"/>
        </setting>
        <setting id="connect_name" type="text" default="" label="11089"
                 help="Blank = this machine's hostname"/>
        <setting id="connect_backend" type="select" values="kodi|alsa" default="kodi" label="11090"/>
        <setting id="connect_player" type="select" values="default|basic" default="default"
                 label="11091" visible="eq(-1,kodi)"/>
        <setting id="connect_alsa_device" type="text" default="default" label="11092"
                 visible="eq(-2,alsa)"/>
        <setting id="connect_dnd_kodi" type="bool" default="false" label="11093">
          <control type="toggle"/>
        </setting>
        <setting id="connect_zeroconf_fixed" type="bool" default="false" label="11094">
          <control type="toggle"/>
        </setting>
        <setting id="connect_zeroconf_port" type="number" default="50252" label="11095"
                 visible="eq(-1,true)"/>
    </category>
</settings>
